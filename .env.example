OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
ALLOWED_ORIGINS=
OPENAI_MODEL=gpt-4o

# Thinkific webhook gate
# Shared secret used by Thinkific to sign enrollment webhooks.
# Set the same value in Thinkific Admin → Settings → Code & Analytics → API Keys / Webhooks.
THINKIFIC_WEBHOOK_SECRET=

# Restrict the gate to a single Thinkific course id (find it in the course URL or admin).
# Strongly recommended — without this, an enrollment in any free course unlocks the tool.
THINKIFIC_COURSE_ID=
